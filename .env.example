# Google (Sheets + Drive) — required for sheet logging + file uploads
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_SHEET_ID=
GOOGLE_DRIVE_ROOT_FOLDER_ID=

# Resend (transactional email) — required for TC alerts + agent confirmations
RESEND_API_KEY=
TC_EMAIL=tc@magenta.realestate
EMAIL_FROM=Magenta TC <tc@magenta.realestate>

# Site URL used in outbound email links
NEXT_PUBLIC_SITE_URL=https://magenta-tc.vercel.app

# Slack (optional) — posts to #tc channel on submissions
SLACK_WEBHOOK_URL=

# Twilio SMS (optional) — text alerts for new files / onboarding
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
TWILIO_TO=
